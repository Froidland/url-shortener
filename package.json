{
	"name": "url-shortener",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"engines": {
		"node": "^24.0.0"
	},
	"scripts": {
		"start": "node --env-file .env build/",
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
